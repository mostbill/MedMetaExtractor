{
  "application": {
    "name": "MedMetaExtractor",
    "version": "1.0.0",
    "description": "Medical metadata extraction tool"
  },
  "dicom": {
    "enabled": false,
    "tags_to_extract": [
      "PatientName",
      "PatientID",
      "StudyDate",
      "Modality",
      "SeriesDescription"
    ]
  },
  "output": {
    "format": "json",
    "pretty_print": true,
    "include_private_tags": false
  },
  "logging": {
    "level": "info",
    "file": "medmeta.log"
  }
}